{
  "name": "Mercado Livre → WhatsApp Afiliados",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 7,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "schedule-atualizar-cookies",
      "name": "Schedule - Atualizar Cookies (7h)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 100]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 7,
              "triggerAtMinute": 5
            }
          ]
        }
      },
      "id": "schedule-buscar-produtos",
      "name": "Schedule - Buscar Produtos (7h05)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 8,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "schedule-gerar-links",
      "name": "Schedule - Gerar Links Afiliado (8h)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 500]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 20,
              "triggerAtMinute": 0,
              "triggerAtSecond": 0
            }
          ]
        }
      },
      "id": "schedule-enviar-whatsapp",
      "name": "Schedule - Enviar WhatsApp (20h-21h a cada 8min)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 700]
    },
    {
      "parameters": {
        "url": "https://www.mercadolivre.com.br",
        "method": "GET",
        "headers": {
          "parameters": [
            {
              "name": "Cookie",
              "value": "={{$node[\"Redis Get Cookies\"].json.body}}"
            },
            {
              "name": "User-Agent",
              "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
            }
          ]
        },
        "responseFormat": "text"
      },
      "id": "http-atualizar-cookies",
      "name": "HTTP - Atualizar Cookies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 100]
    },
    {
      "parameters": {
        "operation": "get",
        "keyName": "ml_cookies"
      },
      "id": "redis-store-cookies",
      "name": "Redis - Salvar Cookies",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [750, 100],
      "credentials": {
        "redis": "redis_default"
      }
    },
    {
      "parameters": {
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Categorias!A:D",
        "firstRowAsHeaders": true
      },
      "id": "google-sheets-listar-categorias",
      "name": "Google Sheets - Listar Categorias",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [500, 300],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "condition": "is equal to",
              "value1": "={{ $json.status }}",
              "value2": "ativo"
            }
          ]
        }
      },
      "id": "filter-categorias-ativas",
      "name": "Filter - Categorias Ativas",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 1,
      "position": [750, 300]
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "method": "GET",
        "headers": {
          "parameters": [
            {
              "name": "Cookie",
              "value": "={{$node[\"Redis Get Cookies\"].json.body}}"
            },
            {
              "name": "User-Agent",
              "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
            }
          ]
        },
        "responseFormat": "text"
      },
      "id": "http-scraping-mercado-livre",
      "name": "HTTP - Requisição Mercado Livre",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "extractors": [
          {
            "key": "productName",
            "selector": "h2.polycomponent.tile__title",
            "returnArray": true
          },
          {
            "key": "productImage",
            "selector": "img.polycomponent.tile__image",
            "returnArray": true,
            "attribute": "src"
          },
          {
            "key": "productUrl",
            "selector": "a.poly-component.thumbnailContainer",
            "returnArray": true,
            "attribute": "href"
          },
          {
            "key": "priceOriginal",
            "selector": "span.poly-component.price__original",
            "returnArray": true
          },
          {
            "key": "priceCurrent",
            "selector": "span.poly-component.price__current-price",
            "returnArray": true
          },
          {
            "key": "discount",
            "selector": "span.poly-component.price__discount",
            "returnArray": true
          }
        ]
      },
      "id": "html-extrair-produtos",
      "name": "HTML - Extrair Dados Produtos",
      "type": "n8n-nodes-base.html",
      "typeVersion": 1,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "fields": {
          "values": [
            {
              "name": "productName",
              "type": "string"
            },
            {
              "name": "productImage",
              "type": "string"
            },
            {
              "name": "productUrl",
              "type": "string"
            },
            {
              "name": "priceOriginal",
              "type": "string"
            },
            {
              "name": "priceCurrent",
              "type": "string"
            },
            {
              "name": "discount",
              "type": "string"
            }
          ]
        },
        "includeBlankDataFields": false
      },
      "id": "split-produtos",
      "name": "Split Out - Separar Produtos",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [1500, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "condition": "is not empty",
              "value1": "={{ $json.productImage }}"
            },
            {
              "condition": "is not empty",
              "value2": "={{ $json.priceCurrent }}"
            },
            {
              "condition": "does not contain",
              "value1": "={{ $json.productUrl }}",
              "value2": "clique.mercadolivre"
            }
          ]
        }
      },
      "id": "filter-produtos-validos",
      "name": "Filter - Produtos Válidos",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 1,
      "position": [1750, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extrair ID do produto da URL\nconst urlMatch = $json.productUrl.match(/MLB(\\d+)/);\nconst productId = urlMatch ? 'MLB' + urlMatch[1] : null;\n\n// Formatar preço\nconst priceCurrentFormatted = parseFloat($json.priceCurrent.replace(/[^\\d,]/g, '').replace(',', '.')).toFixed(2);\nconst priceOriginalFormatted = parseFloat($json.priceOriginal.replace(/[^\\d,]/g, '').replace(',', '.')).toFixed(2);\n\n// Calcular desconto em percentual\nconst discountPercent = ((parseFloat(priceOriginalFormatted) - parseFloat(priceCurrentFormatted)) / parseFloat(priceOriginalFormatted) * 100).toFixed(0);\n\nreturn {\n  ...item,\n  productId: productId,\n  priceCurrentFormatted: priceCurrentFormatted,\n  priceOriginalFormatted: priceOriginalFormatted,\n  discountPercent: discountPercent,\n  status: 'processando',\n  createdAt: new Date().toISOString(),\n  randomOrder: Math.random()\n};"
      },
      "id": "code-processar-dados",
      "name": "Code - Processar Dados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [2000, 300]
    },
    {
      "parameters": {
        "mode": "overwrite",
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Produtos!A:L",
        "columns": "productId, productName, productImage, productUrl, priceCurrentFormatted, priceOriginalFormatted, discountPercent, discount, status, createdAt, randomOrder"
      },
      "id": "google-sheets-atualizar-produtos",
      "name": "Google Sheets - Inserir Produtos",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [2250, 300],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    },
    {
      "parameters": {
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Produtos!A:L",
        "firstRowAsHeaders": true,
        "options": {
          "valueRenderOption": "UNFORMATTED_VALUE"
        }
      },
      "id": "google-sheets-ler-produtos",
      "name": "Google Sheets - Ler Produtos (Links)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [500, 500],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "condition": "is equal to",
              "value1": "={{ $json.status }}",
              "value2": "processando"
            }
          ]
        }
      },
      "id": "filter-produtos-pendentes",
      "name": "Filter - Produtos Pendentes Links",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 1,
      "position": [750, 500]
    },
    {
      "parameters": {
        "url": "https://api.mercadolibre.com/sites/MLB/domain_discovery/search?q={{encodeURIComponent($json.productName)}}",
        "method": "GET",
        "headers": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$credentials.mercado_livre_api.accessToken}}"
            }
          ]
        }
      },
      "id": "http-mercado-livre-api",
      "name": "HTTP - Mercado Livre API (Link Afiliado)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1000, 500],
      "credentials": {
        "httpBasicAuth": "mercado_livre_credentials"
      }
    },
    {
      "parameters": {
        "jsCode": "// Gerar link de afiliado\nconst productUrl = $json.productUrl;\nconst affiliateId = 'SEU_ID_AFILIADO'; // Substituir com seu ID\nconst affiliateLink = productUrl.includes('?') ? \n  `${productUrl}&affiliate_id=${affiliateId}` : \n  `${productUrl}?affiliate_id=${affiliateId}`;\n\nreturn {\n  ...item,\n  affiliateLink: affiliateLink,\n  status: 'pronto'\n};"
      },
      "id": "code-gerar-link-afiliado",
      "name": "Code - Gerar Link Afiliado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1250, 500]
    },
    {
      "parameters": {
        "mode": "update",
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Produtos",
        "keyToMatch": "productId",
        "columns": "affiliateLink, status"
      },
      "id": "google-sheets-atualizar-links",
      "name": "Google Sheets - Atualizar Links",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [1500, 500],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    },
    {
      "parameters": {
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Produtos!A:L",
        "firstRowAsHeaders": true,
        "options": {
          "valueRenderOption": "UNFORMATTED_VALUE"
        }
      },
      "id": "google-sheets-ler-para-enviar",
      "name": "Google Sheets - Ler Produtos (Enviar)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [500, 700],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {
              "condition": "is equal to",
              "value1": "={{ $json.status }}",
              "value2": "pronto"
            }
          ]
        }
      },
      "id": "filter-pronto-enviar",
      "name": "Filter - Status = Pronto",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 1,
      "position": [750, 700]
    },
    {
      "parameters": {
        "limit": 1,
        "offset": 0,
        "mode": "first"
      },
      "id": "limit-um-produto",
      "name": "Limit - 1 Produto por Execução",
      "type": "n8n-nodes-base.limit",
      "typeVersion": 1,
      "position": [1000, 700]
    },
    {
      "parameters": {
        "jsCode": "// Gerar delay aleatório entre 1-2 minutos\nconst delayMs = Math.floor(Math.random() * 60000) + 60000; // 60s-120s\nreturn { delayMs: delayMs };"
      },
      "id": "code-delay-aleatorio",
      "name": "Code - Delay Aleatório (1-2min)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1250, 700]
    },
    {
      "parameters": {
        "waitValue": "={{ $json.delayMs }}",
        "unit": "milliseconds"
      },
      "id": "wait-delay",
      "name": "Wait - Aguardar",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1500, 700]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/api/groups",
        "method": "GET",
        "headers": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$credentials.usap_api_key}}"
            }
          ]
        }
      },
      "id": "http-usap-listar-grupos",
      "name": "HTTP - USAP Listar Grupos WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1750, 700]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/api/messages/send",
        "method": "POST",
        "headers": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$credentials.usap_api_key}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "body": {
          "raw": "{\n  \"chatId\": \"{{$env.WHATSAPP_GROUP_JID}}\",\n  \"text\": \"🏷️ *{{$json.productName}}*\\n\\n💰 *Preço:* R$ {{$json.priceCurrentFormatted}}\\n💸 *De:* R$ {{$json.priceOriginalFormatted}}\\n📉 *Desconto:* {{$json.discountPercent}}%\\n\\n🔗 Link: {{$json.affiliateLink}}\",\n  \"image\": \"{{$json.productImage}}\"\n}"
        }
      },
      "id": "http-usap-enviar-mensagem",
      "name": "HTTP - USAP Enviar Mensagem",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2000, 700]
    },
    {
      "parameters": {
        "mode": "update",
        "documentId": {
          "__rlc": {
            "value": "{{$credentials.google_sheets.sheetId}}",
            "mode": "id"
          }
        },
        "range": "Produtos",
        "keyToMatch": "productId",
        "columns": "status",
        "values": "enviado"
      },
      "id": "google-sheets-marcar-enviado",
      "name": "Google Sheets - Marcar como Enviado",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.0,
      "position": [2250, 700],
      "credentials": {
        "googleSheetsOAuth2": "google_sheets_oauth"
      }
    }
  ],
  "connections": {
    "schedule-atualizar-cookies": {
      "main": [
        [
          {
            "node": "http-atualizar-cookies",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "http-atualizar-cookies": {
      "main": [
        [
          {
            "node": "redis-store-cookies",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "schedule-buscar-produtos": {
      "main": [
        [
          {
            "node": "google-sheets-listar-categorias",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "google-sheets-listar-categorias": {
      "main": [
        [
          {
            "node": "filter-categorias-ativas",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "filter-categorias-ativas": {
      "main": [
        [
          {
            "node": "http-scraping-mercado-livre",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "http-scraping-mercado-livre": {
      "main": [
        [
          {
            "node": "html-extrair-produtos",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "html-extrair-produtos": {
      "main": [
        [
          {
            "node": "split-produtos",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "split-produtos": {
      "main": [
        [
          {
            "node": "filter-produtos-validos",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "filter-produtos-validos": {
      "main": [
        [
          {
            "node": "code-processar-dados",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "code-processar-dados": {
      "main": [
        [
          {
            "node": "google-sheets-atualizar-produtos",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "schedule-gerar-links": {
      "main": [
        [
          {
            "node": "google-sheets-ler-produtos",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "google-sheets-ler-produtos": {
      "main": [
        [
          {
            "node": "filter-produtos-pendentes",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "filter-produtos-pendentes": {
      "main": [
        [
          {
            "node": "code-gerar-link-afiliado",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "code-gerar-link-afiliado": {
      "main": [
        [
          {
            "node": "google-sheets-atualizar-links",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "schedule-enviar-whatsapp": {
      "main": [
        [
          {
            "node": "google-sheets-ler-para-enviar",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "google-sheets-ler-para-enviar": {
      "main": [
        [
          {
            "node": "filter-pronto-enviar",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "filter-pronto-enviar": {
      "main": [
        [
          {
            "node": "limit-um-produto",
            "branch": 0,
            "pin": 0
          }
        ]
      ]
    },
    "limit-um-produto": {
      "main": [
        [
          {
            "node": "code-delay-aleatorio",
